NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/contratos?schema=public

JWT_SECRET=change-this-jwt-secret-with-at-least-32-chars-in-production
JWT_ISSUER=geo-projetos-api
JWT_AUDIENCE=geo-projetos-web
JWT_EXPIRES_IN=12h

ADMIN_USER=admin
ADMIN_PASS=admin123

# Comma-separated allowlist. Leave empty to use local defaults in development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false
ENABLE_HSTS=false

# Required outside development. Optional in development.
SETUP_TOKEN=change-this-setup-token
